

# Groq API Key (get free key at: https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# LLM Model (default: llama-3.3-70b-versatile)
# Other options: mixtral-8x7b-32768, llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

RERANKER_MODEL=BAAI/bge-reranker-base

QDRANT_PATH=./data/qdrant_store
QDRANT_COLLECTION=financial_rag

BM25_INDEX_PATH=./data/bm25_index

# Processed Documents Cache
PROCESSED_DOCS_PATH=./data/processed

# Raw PDFs Directory
RAW_PDFS_PATH=./raw_pdfs

# Device (auto / cuda / cpu)
DEVICE=auto

USE_TF=0
USE_TORCH=1

LOG_LEVEL=INFO
